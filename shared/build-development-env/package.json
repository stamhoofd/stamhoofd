        "build": "tsc --build tsconfig.build.json",
        "lint": "eslint .",
        "start": "node dist/init.js"
    },
    "dependencies": {
        "@stamhoofd/types": "2.122.9",
        "@stamhoofd/utility": "2.122.9",
        "chalk": "5.6.2"
    },
    "devDependencies": {
        "concurrently": "10.0.3"
    },
    "license": "UNLICENCED",
    "publishConfig": {
        "access": "public"
    }
