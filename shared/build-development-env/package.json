{
    "name": "@stamhoofd/build-development-env",
    "version": "2.121.0",
    "type": "module",
    "types": "./dist/index.d.ts",
    "module": "./dist/index.js",
    "main": "./dist/index.js",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "package.json"
    ],
    "license": "UNLICENCED",
    "sideEffects": false,
    "scripts": {
        "start": "node dist/init.js",
        "build": "tsc --build tsconfig.build.json",
        "lint": "eslint ."
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@stamhoofd/types": "*",
        "@stamhoofd/utility": "*",
        "chalk": "^4.1.2"
    },
    "devDependencies": {
        "concurrently": "^10.0.3"
    }
}
