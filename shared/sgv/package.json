{
    "name": "@stamhoofd/sgv",
    "version": "2.121.0",
    "type": "module",
    "types": "./dist/index.d.ts",
    "module": "./dist/index.js",
    "main": "./dist/index.js",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js"
        },
        "./*": {
            "types": "./dist/*.d.ts",
            "import": "./dist/*.js",
            "require": "./dist/*.js"
        }
    },
    "files": [
        "dist",
        "package.json"
    ],
    "license": "UNLICENSED",
    "sideEffects": false,
    "scripts": {
        "build": "tsc --build tsconfig.build.json",
        "test": "vitest",
        "lint": "eslint ."
    },
    "dependencies": {
        "@simonbackx/simple-encoding": "2.26.8",
        "@simonbackx/simple-errors": "1.5.0",
        "@stamhoofd/structures": "*",
        "@stamhoofd/types": "*",
        "@stamhoofd/utility": "*"
    },
    "devDependencies": {
        "vitest": "4.1.8"
    },
    "publishConfig": {
        "access": "public"
    }
}
