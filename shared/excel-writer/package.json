{
    "name": "@stamhoofd/excel-writer",
    "version": "2.136.3",
    "type": "module",
    "main": "./dist/index.d.ts",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js"
        },
        "./core": {
            "types": "./dist/core.d.ts",
            "import": "./dist/core.js",
            "require": "./dist/core.js"
        }
    },
    "files": [
        "dist",
        "package.json"
    ],
    "scripts": {
        "build": "tsc --build tsconfig.build.json",
        "lint": "eslint"
    },
    "dependencies": {
        "@simonbackx/simple-errors": "1.5.0",
        "uuid": "14.0.0"
    },
    "devDependencies": {
        "@types/archiver": "6.0.3",
        "@types/luxon": "3.7.1",
        "@types/uuid": "8.3.4"
    },
    "peerDependencies": {
        "@stamhoofd/utility": "*",
        "archiver": "7.0.1"
    },
    "license": "UNLICENCED",
    "publishConfig": {
        "access": "public"
    }
}
