{
    "name": "@stamhoofd/test-utils",
    "version": "2.119.0",
    "type": "module",
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.js",
    "types": "./dist/esm/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js",
            "types": "./dist/esm/index.d.ts"
        },
        "./cjs": {
            "import": "./dist/cjs/index.js",
            "require": "./dist/cjs/index.js",
            "types": "./dist/cjs/index.d.ts"
        }
    },
    "files": [
        "dist/cjs",
        "dist/esm",
        "package.json"
    ],
    "license": "UNLICENCED",
    "sideEffects": false,
    "scripts": {
        "build": "tsc --build tsconfig.cjs.json tsconfig.esm.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
        "lint": "eslint ."
    },
    "publishConfig": {
        "access": "public"
    }
}
