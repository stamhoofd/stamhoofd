{
    // File used when building the package.
    "extends": "../tsconfig.base.json",
    "compilerOptions": {
        "outDir": "./dist/cjs",
        "types": [
            "node",
            "jest"
        ],
    },
    "include": [
        "./*.ts",
        "./src/**/*.ts",
        "./src/**/*.json",
        "../stamhoofd.d.ts"
    ],
    "exclude": [
        // Tests are excluded (only included in tsconfig.test.json)
        "src/**/*.spec.ts", 
        "src/**/*.test.ts"
    ]
}
