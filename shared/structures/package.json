{
    "name": "@stamhoofd/structures",
    "version": "2.123.1",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "sideEffects": [
        "./src/circular-dependencies/*.ts",
        "./src/index.ts",
        "./dist/circular-dependencies/*.js",
        "./dist/index.js",
        "./src/Version.ts",
        "./dist/Version.js"
    ],
    "exports": {
        ".": "./dist/index.js",
        "./*.js": "./dist/*.js"
    },
    "files": [
        "dist",
        "package.json"
    ],
    "scripts": {
        "build": "tsc --build tsconfig.build.json",
        "lint": "eslint",
        "test": "vitest",
        "test:coverage": "vitest --coverage"
    },
    "dependencies": {
        "@simonbackx/simple-encoding": "2.26.10"
    },
    "devDependencies": {
        "@simonbackx/simple-errors": "1.5.0",
        "@stamhoofd/test-utils": "2.123.1",
        "@types/uuid": "8.3.4",
        "uuid": "14.0.0",
        "vitest": "4.1.8"
    },
    "peerDependencies": {
        "@simonbackx/simple-errors": "1.5.0",
        "@stamhoofd/types": "*",
        "@stamhoofd/utility": "*",
        "uuid": "14.0.0"
    },
    "license": "UNLICENCED",
    "publishConfig": {
        "access": "public"
    }
}
