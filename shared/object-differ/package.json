{
    "name": "@stamhoofd/object-differ",
    "version": "2.119.0",
    "type": "module",
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.js",
    "types": "./dist/esm/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js",
            "types": "./dist/esm/index.d.ts"
        }
    },
    "files": [
        "dist/cjs",
        "dist/esm",
        "package.json"
    ],
    "license": "UNLICENCED",
    "sideEffects": [],
    "scripts": {
        "build": "tsc --build tsconfig.cjs.json tsconfig.esm.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
        "lint": "eslint"
    },
    "devDependencies": {
        "@types/uuid": "^8.3.0",
        "uuid": "11.0.3"
    },
    "peerDependencies": {
        "uuid": "11.0.3"
    },
    "publishConfig": {
        "access": "public"
    }
}
