{
    "name": "@stamhoofd/locales",
    "version": "2.126.0",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js"
        },
        "./locales/*": {
            "types": "./dist/locales/*",
            "import": "./dist/locales/*",
            "require": "./dist/locales/*"
        }
    },
    "files": [
        "dist",
        "package.json"
    ],
    "scripts": {
        "build": "tsc --build tsconfig.build.json && node build.js"
    },
    "license": "UNLICENCED"
}
