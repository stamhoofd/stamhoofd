{
    "name": "@stamhoofd/locales",
    "version": "2.119.0",
    "license": "UNLICENCED",
    "type": "module",
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.js",
    "types": "./dist/esm/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js",
            "types": "./dist/esm/index.d.ts"
        },
        "./locales": "./dist/locales"
    },
    "files": [
        "dist/cjs",
        "dist/esm",
        "dist/locales",
        "package.json"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "tsc --build tsconfig.cjs.json tsconfig.esm.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json && node build.mjs"
    }
}
