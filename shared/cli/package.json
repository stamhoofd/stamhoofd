{
    "name": "@stamhoofd/cli",
    "version": "2.121.0",
    "type": "module",
    "types": "./dist/index.d.ts",
    "module": "./dist/index.js",
    "main": "./dist/index.js",
    "bin": {
        "stam": "./bin/stam.js"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js"
        }
    },
    "files": [
        "bin",
        "dist",
        "package.json"
    ],
    "license": "UNLICENSED",
    "sideEffects": false,
    "scripts": {
        "build": "rm -rf dist && tsc --build tsconfig.build.json --force",
        "lint": "eslint .",
        "test": "vitest run"
    },
    "dependencies": {
        "@inquirer/prompts": "^7.8.6",
        "@oclif/core": "^4.2.10",
        "chalk": "^5.6.2",
        "log-update": "^8.0.0",
        "ora": "^9.0.0",
        "terminal-link": "^4.0.0"
    },
    "oclif": {
        "bin": "stam",
        "description": "Stamhoofd development CLI",
        "commands": "./dist/commands",
        "helpClass": "./dist/help.js",
        "topicSeparator": " ",
        "theme": {
            "sectionHeader": "cyan",
            "command": "cyan",
            "commandSummary": "white",
            "flag": "yellow",
            "flagDefaultValue": "dim",
            "flagOptions": "dim",
            "flagRequired": "yellow",
            "flagSeparator": "dim",
            "bin": "green",
            "dollarSign": "dim",
            "topic": "cyan",
            "sectionDescription": "white",
            "version": "magenta"
        }
    }
}
