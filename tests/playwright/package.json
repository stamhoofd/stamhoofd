{
    "name": "@stamhoofd/playwright",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "test": "yarn -s build && NODE_OPTIONS=--use-system-ca NODE_ENV=test STAMHOOFD_ENV=playwright DEBUG=pw:browser* playwright test -c dist",
        "test:skip": "STAMHOOFD_SKIP_FRONTEND_BUILD=true yarn -s test",
        "test:trace": "yarn -s test --trace on",
        "test:skip:trace": "yarn -s test:skip --trace on",
        "test:extra": "PLAYWRIGHT_INCLUDE_EXTRA=1 yarn -s test --grep @extra",
        "test:extra:skip": "STAMHOOFD_SKIP_FRONTEND_BUILD=true yarn -s test:extra",
        "lint": "eslint",
        "build": "tsc --build"
    },
    "dependencies": {
        "@simonbackx/simple-database": "1.36.12",
        "pino": "^10.1.1"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2"
    }
}
