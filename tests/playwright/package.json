{
    "name": "@stamhoofd/playwright",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "test": "pnpm -s build && NODE_OPTIONS=--use-system-ca NODE_ENV=test STAMHOOFD_ENV=playwright DEBUG=pw:browser* playwright test -c dist",
        "test:trace": "pnpm -s test --trace on",
        "test:extra": "PLAYWRIGHT_INCLUDE_EXTRA=1 pnpm -s test --grep @extra",
        "lint": "eslint",
        "build": "pnpm --dir ../../backend/app/api -s build:playwright:pre && tsc --build"
    },
    "dependencies": {
        "@simonbackx/simple-database": "1.36.12",
        "@stamhoofd/backend": "*",
        "@stamhoofd/build-development-env": "*",
        "@stamhoofd/models": "*",
        "@stamhoofd/structures": "*",
        "@stamhoofd/test-utils": "*",
        "@stamhoofd/utility": "*",
        "pino": "^10.1.1"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2"
    }
}
