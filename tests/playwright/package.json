{
    "name": "@stamhoofd/playwright",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "tsc --build",
        "lint": "eslint",
        "test": "yarn -s build && NODE_OPTIONS=--use-system-ca NODE_ENV=test STAMHOOFD_ENV=playwright DEBUG=pw:browser* playwright test -c dist",
        "test:extra": "PLAYWRIGHT_INCLUDE_EXTRA=1 yarn -s test --grep @extra",
        "test:trace": "yarn -s test --trace on"
    },
    "dependencies": {
        "@simonbackx/simple-database": "1.37.1",
        "@stamhoofd/backend": "*",
        "@stamhoofd/backend-i18n": "*",
        "@stamhoofd/cli": "*",
        "@stamhoofd/email": "*",
        "@stamhoofd/models": "*",
        "@stamhoofd/structures": "*",
        "@stamhoofd/types": "*",
        "@stamhoofd/utility": "*",
        "@simonbackx/simple-encoding": "*",
        "pino": "10.1.1"
    },
    "devDependencies": {
        "@playwright/test": "1.60.0",
        "@stamhoofd/test-utils": "*",
        "eslint-plugin-stamhoofd": "*",
        "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.2/xlsx-0.20.2.tgz"
    }
}
