{
    "name": "@stamhoofd/backend-i18n",
    "version": "2.119.0",
    "type": "module",
    "types": "./dist/index.d.ts",
    "main": "./dist/index.js",
    "license": "UNLICENCED",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "require": "./dist/index.js",
            "import": "./dist/index.js"
        },
        "./*": {
            "types": "./dist/*.d.ts",
            "require": "./dist/*.js",
            "import": "./dist/*.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc --build tsconfig.build.json",
        "lint": "eslint"
    },
    "peerDependencies": {
        "@simonbackx/simple-endpoints": "*"
    },
    "publishConfig": {
        "access": "public"
    }
}
