{
    "name": "@stamhoofd/models",
    "version": "2.126.2",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "sideEffects": [
        "./src/models/_relations.ts",
        "./dist/models/_relations.js"
    ],
    "exports": {
        ".": "./dist/index.js",
        "./*.ts": "./dist/*.js",
        "./*.js": "./dist/*.js"
    },
    "imports": {
        "#*": "./src/*.ts",
        "#*.ts": "./src/*.ts"
    },
    "files": [
        "dist",
        "src"
    ],
    "scripts": {
        "build": "tsc --build tsconfig.build.json && mkdir -p ./dist/migrations && rsync --delete --exclude='*.ts' --exclude='*.js' --exclude='*.map' -r --checksum ./src/migrations/ ./dist/migrations/ && rsync -r --checksum ./src/assets/ ./dist/assets/",
        "lint": "eslint",
        "test": "vitest",
        "test:coverage": "vitest --coverage"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "3.1068.0",
        "@aws-sdk/client-sesv2": "3.1068.0",
        "@bwip-js/node": "4.11.1",
        "@mollie/api-client": "4.5.0",
        "@simonbackx/simple-encoding": "2.26.10",
        "@simonbackx/simple-endpoints": "1.21.1",
        "@simonbackx/simple-errors": "1.5.0",
        "argon2": "0.44.0",
        "base-x": "3.0.11",
        "handlebars": "4.7.9",
        "sharp": "0.35.1"
    },
    "devDependencies": {
        "@simonbackx/simple-database": "1.37.1",
        "@stamhoofd/test-utils": "2.126.2",
        "@types/luxon": "3.7.1",
        "@types/uuid": "8.3.4",
        "vitest": "4.1.8"
    },
    "peerDependencies": {
        "@simonbackx/simple-database": "1.37.1",
        "@stamhoofd/backend-i18n": "*",
        "@stamhoofd/email": "*",
        "@stamhoofd/queues": "*",
        "@stamhoofd/sql": "*",
        "@stamhoofd/structures": "*",
        "@stamhoofd/types": "*",
        "@stamhoofd/utility": "*"
    },
    "license": "UNLICENCED",
    "publishConfig": {
        "access": "public"
    }
}
