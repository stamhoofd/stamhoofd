{
    "name": "@stamhoofd/models",
    "version": "2.121.0",
    "type": "module",
    "types": "./dist/index.d.ts",
    "main": "./dist/index.js",
    "license": "UNLICENCED",
    "sideEffects": [
        "./src/models/_relations.ts",
        "./dist/models/_relations.js"
    ],
    "exports": {
        ".": "./dist/index.js",
        "./*.ts": "./dist/*.js",
        "./*.js": "./dist/*.js"
    },
    "imports": {
        "#*": "./src/*.ts",
        "#*.ts": "./src/*.ts"
    },
    "files": [
        "dist",
        "src"
    ],
    "scripts": {
        "build": "tsc --build tsconfig.build.json && mkdir -p ./dist/migrations && rsync --delete --exclude='*.ts' --exclude='*.js' --exclude='*.map' -r --checksum ./src/migrations/ ./dist/migrations/ && rsync -r --checksum ./src/assets/ ./dist/assets/",
        "test": "vitest",
        "lint": "eslint"
    },
    "peerDependencies": {
        "@simonbackx/simple-database": "1.36.12",
        "@stamhoofd/email": "*",
        "@stamhoofd/queues": "*"
    },
    "dependencies": {
        "@simonbackx/simple-encoding": "2.26.6",
        "@simonbackx/simple-errors": "^1.5",
        "@aws-sdk/client-s3": "^3.839.0",
        "@aws-sdk/client-sesv2": "^3.839.0",
        "@bwip-js/node": "^4.5.1",
        "@mollie/api-client": "4.5.0",
        "@stamhoofd/backend-i18n": "*",
        "@stamhoofd/email": "*",
        "@stamhoofd/queues": "*",
        "@stamhoofd/sql": "*",
        "@stamhoofd/structures": "*",
        "@stamhoofd/types": "*",
        "@stamhoofd/utility": "*",
        "argon2": "^0.40.1",
        "base-x": "^3.0.11",
        "handlebars": "^4.7.7",
        "luxon": "3.4.4",
        "sharp": "^0.34.2",
        "uuid": "11.0.3"
    },
    "devDependencies": {
        "@simonbackx/simple-database": "1.36.12"
    },
    "publishConfig": {
        "access": "public"
    }
}
