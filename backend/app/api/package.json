{
    "name": "@stamhoofd/backend",
    "version": "2.121.0",
    "type": "module",
    "main": "./dist/index.js",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js"
        },
        "./migrate": {
            "types": "./dist/src/migrate.d.ts",
            "import": "./dist/src/migrate.js",
            "require": "./dist/src/migrate.js"
        },
        "./boot": {
            "types": "./dist/src/boot.d.ts",
            "import": "./dist/src/boot.js",
            "require": "./dist/src/boot.js"
        },
        "./tests/helpers": {
            "@stamhoofd/source": "./tests/helpers/index.ts",
            "types": "./dist/tests/helpers/index.d.ts",
            "import": "./dist/tests/helpers/index.js",
            "require": "./dist/tests/helpers/index.js"
        }
    },
    "license": "UNLICENCED",
    "scripts": {
        "dev": "wait-on ../../shared/middleware/dist/index.js && concurrently -r 'yarn -s build --watch --preserveWatchOutput' \"yarn -s dev:watch\"",
        "dev:build": "yarn -s build",
        "dev:full": "yarn -s dev",
        "dev:watch": "wait-on ./dist/index.js && nodemon --quiet --inspect=5858 --watch dist --watch '../../../shared/*/dist/' --watch '../../../shared/*/package.json' --watch '../../shared/*/dist/' --watch '../../shared/*/package.json' --ext .ts,.json,.sql,.js,.html --delay 2000ms --exec 'echo \"Restarting API...\" && exec node --enable-source-maps --use-system-ca ./dist/index.js' --signal SIGTERM",
        "dev:backend": "yarn -s dev",
        "build": "tsc --build tsconfig.build.json --clean && yarn -s copy-assets && tsc --build tsconfig.build.json",
        "build:playwright:pre": "yarn -s build && tsc --build tsconfig.test.json",
        "copy-assets": "rsync --delete --mkpath --exclude='*.ts' --exclude='*.js' --exclude='*.map' -r --checksum ./src/ ./dist/src/",
        "build:full": "yarn -s clear && yarn -s build",
        "clear": "rm -rf ./dist && rm -f *.tsbuildinfo",
        "start": "yarn -s build && node --enable-source-maps ./dist/index.js",
        "test": "vitest",
        "test:coverage": "vitest --coverage",
        "test:reset": "yarn -s build:full && yarn -s test",
        "migrations": "yarn -s build:full && node ./dist/migrations.js",
        "lint": "eslint"
    },
    "devDependencies": {
        "@stamhoofd/test-utils": "*",
        "@types/cookie": "^0.6.0",
        "@types/luxon": "3.7.1",
        "@types/mailparser": "^3",
        "@types/mysql": "^2.15.20",
        "@types/node": "^22",
        "@types/uuid": "^8.3.0",
        "nock": "^14.0.10",
        "qs": "^6.11.2",
        "sinon": "^18.0.0",
        "vitest": "^4.1.8"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.839.0",
        "@aws-sdk/client-ses": "^3.839.0",
        "@aws-sdk/client-sesv2": "^3.839.0",
        "@aws-sdk/client-sqs": "^3.839.0",
        "@aws-sdk/s3-request-presigner": "^3.839.0",
        "@bwip-js/node": "^4.5.1",
        "@mollie/api-client": "4.5.0",
        "@simonbackx/simple-database": "1.37.1",
        "@simonbackx/simple-encoding": "2.26.8",
        "@simonbackx/simple-endpoints": "1.21.1",
        "@simonbackx/simple-errors": "^1.5",
        "@simonbackx/simple-logging": "^1.0.1",
        "@stamhoofd/backend-env": "*",
        "@stamhoofd/backend-i18n": "*",
        "@stamhoofd/backend-middleware": "*",
        "@stamhoofd/crons": "*",
        "@stamhoofd/email": "*",
        "@stamhoofd/excel-writer": "*",
        "@stamhoofd/logging": "*",
        "@stamhoofd/models": "*",
        "@stamhoofd/object-differ": "*",
        "@stamhoofd/queues": "*",
        "@stamhoofd/sql": "*",
        "@stamhoofd/structures": "*",
        "@stamhoofd/types": "*",
        "@stamhoofd/utility": "*",
        "archiver": "^7.0.1",
        "axios": "^1.16.0",
        "base-x": "^3.0.11",
        "chalk": "^4.1.2",
        "cookie": "^0.7.0",
        "formidable": "3.5.4",
        "handlebars": "^4.7.9",
        "jose": "^5.9.6",
        "jsonwebtoken": "9.0.3",
        "jsvat-next": "3.0.4",
        "libphonenumber-js": "^1.12.38",
        "luxon": "3.7.2",
        "mailparser": "3.9.9",
        "mockdate": "^3.0.2",
        "mysql2": "^3.20.0",
        "node-rsa": "2.0.0",
        "openid-client": "^5.4.0",
        "stripe": "^16.6.0"
    },
    "publishConfig": {
        "access": "public"
    }
}
