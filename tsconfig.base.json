{
    "compilerOptions": {
        "allowSyntheticDefaultImports": true,
        "composite": true,
        "declaration": true,
        "declarationMap": true,
        "esModuleInterop": true,
        "experimentalDecorators": true,
        "forceConsistentCasingInFileNames": true,
        "importHelpers": true,
        "isolatedModules": true,
        "jsx": "preserve",
        "lib": [
            "es2023",
            "dom"
        ],
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "noErrorTruncation": true,
        // TS 6 defaults this to true; pin to keep the previous side-effect import behavior.
        "noUncheckedSideEffectImports": false,
        "resolveJsonModule": true,
        "sourceMap": true,
        // TS 6 enables `strict` by default. The backend has only ever opted into
        // `strictNullChecks`, so keep `strict` off to avoid turning on noImplicitAny etc.
        "strict": false,
        "strictNullChecks": true,
        "target": "es2023",
        "types": [
            "node"
        ],
        "useDefineForClassFields": true
    }
}
