{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2023"],
        "types": ["node"],
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true,
        "esModuleInterop": true
    },
    "include": ["src/**/*.ts"]
}
