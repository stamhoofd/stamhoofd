{
    "name": "i18n-uuid",
    "version": "1.0.0",
    "type": "module",
    "types": "./dist/index.d.ts",
    "main": "./dist/index.js",
    "license": "MIT",
    "private": true,
    "scripts": {
        "build": "tsc --build tsconfig.build.json",
        "start": "yarn -s build && node --enable-source-maps ./dist/index.js start",
        "replace-text": "yarn -s build && node --enable-source-maps ./dist/index.js replace-text",
        "unused-keys": "yarn -s build && node --enable-source-maps ./dist/index.js unused-keys",
        "merge-duplicates": "yarn -s build && node --enable-source-maps ./dist/index.js merge-duplicates",
        "compress-uuids": "yarn -s build && node --enable-source-maps ./dist/index.js compress-uuids",
        "clear-cache": "yarn -s build && node --enable-source-maps ./dist/index.js clear-cache",
        "replace-keys": "yarn -s build && node --enable-source-maps ./dist/index.js replace-keys",
        "auto-translate": "yarn -s build && node --enable-source-maps ./dist/index.js auto-translate",
        "filter-invalid-auto-translations": "yarn -s build && node --enable-source-maps ./dist/index.js filter-invalid-auto-translations",
        "loop-invalid-auto-translations": "yarn -s build && node --enable-source-maps ./dist/index.js loop-invalid-auto-translations",
        "fix-double-translations": "yarn -s build && node --enable-source-maps ./dist/index.js fix-double-translations",
        "create-comparison": "yarn -s build && node --enable-source-maps ./dist/index.js create-comparison",
        "test": "vitest",
        "lint": "eslint",
        "test:coverage": "vitest --coverage"
    },
    "devDependencies": {
        "@anthropic-ai/sdk": "0.104.2",
        "@google/generative-ai": "0.24.1",
        "@mistralai/mistralai": "1.15.1",
        "chalk": "4.1.2",
        "commander": "13.1.0",
        "dotenv": "16.6.1",
        "eslint-plugin-stamhoofd": "*",
        "fast-xml-parser": "5.10.1",
        "openai": "4.104.0",
        "typescript": "5.9.3",
        "uuid": "14.0.0",
        "vitest": "4.1.8",
        "winston": "3.19.0"
    }
}
