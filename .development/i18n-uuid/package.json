{
    "name": "i18n-uuid",
    "version": "1.0.0",
    "type": "module",
    "types": "./dist/index.d.ts",
    "main": "./dist/index.js",
    "license": "MIT",
    "private": true,
    "scripts": {
        "build": "tsc --build tsconfig.build.json",
        "start": "pnpm -s build && node --enable-source-maps ./dist/index.js start",
        "replace-text": "pnpm -s build && node --enable-source-maps ./dist/index.js replace-text",
        "unused-keys": "pnpm -s build && node --enable-source-maps ./dist/index.js unused-keys",
        "merge-duplicates": "pnpm -s build && node --enable-source-maps ./dist/index.js merge-duplicates",
        "compress-uuids": "pnpm -s build && node --enable-source-maps ./dist/index.js compress-uuids",
        "clear-cache": "pnpm -s build && node --enable-source-maps ./dist/index.js clear-cache",
        "replace-keys": "pnpm -s build && node --enable-source-maps ./dist/index.js replace-keys",
        "auto-translate": "pnpm -s build && node --enable-source-maps ./dist/index.js auto-translate",
        "filter-invalid-auto-translations": "pnpm -s build && node --enable-source-maps ./dist/index.js filter-invalid-auto-translations",
        "loop-invalid-auto-translations": "pnpm -s build && node --enable-source-maps ./dist/index.js loop-invalid-auto-translations",
        "fix-double-translations": "pnpm -s build && node --enable-source-maps ./dist/index.js fix-double-translations",
        "create-comparison": "pnpm -s build && node --enable-source-maps ./dist/index.js create-comparison",
        "test": "vitest",
        "lint": "eslint"
    },
    "devDependencies": {
        "@anthropic-ai/sdk": "^0.39.0",
        "@google/generative-ai": "^0.22.0",
        "@mistralai/mistralai": "^1.5.0",
        "chalk": "4",
        "commander": "^13.1.0",
        "dotenv": "^16.4.5",
        "eslint-plugin-stamhoofd": "*",
        "fast-xml-parser": "^5.7.2",
        "openai": "^4.86.2",
        "typescript": "^5.9.3",
        "uuid": "11.0.3",
        "vitest": "3",
        "winston": "^3.17.0"
    }
}
