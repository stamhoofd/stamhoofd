{
  "name": "@stamhoofd/mobile",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "android": "cap open android",
    "build": "NODE_OPTIONS=\"--max-old-space-size=8192 --max-semi-space-size=128\" NODE_ENV=development ENV_FILE=../../.env.json vite build",
    "build:production": "NODE_OPTIONS=\"--max-old-space-size=8192 --max-semi-space-size=128\" NODE_ENV=production vite build",
    "ios": "cap open ios",
    "lint": "eslint",
    "serve": "NODE_ENV=development ENV_FILE=../../.env.json vite",
    "sync": "cap sync",
    "sync:production": "yarn -s trapeze && cap sync",
    "trapeze": "trapeze run config.yaml -y && trapeze run entitlements.yaml -y && trapeze run display-name.yaml -y"
  },
  "dependencies": {
    "@capacitor-community/in-app-review": "8.0.0",
    "@capacitor/android": "^8.0.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/app-launcher": "^8.0.0",
    "@capacitor/assets": "3.0.5",
    "@capacitor/core": "^8.0.0",
    "@capacitor/filesystem": "^8.0.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/preferences": "^8.0.0",
    "@capacitor/share": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0",
    "@capgo/capacitor-updater": "8.49.4",
    "@simonbackx/simple-encoding": "2.26.11",
    "@simonbackx/simple-networking": "1.23.0",
    "@simonbackx/vue-app-navigation": "2.24.0",
    "@stamhoofd/assets": "*",
    "@stamhoofd/components": "*",
    "@stamhoofd/dashboard": "*",
    "@stamhoofd/document-helper": "*",
    "@stamhoofd/web-app": "*",
    "@stamhoofd/frontend-excel-export": "*",
    "@stamhoofd/frontend-i18n": "*",
    "@stamhoofd/frontend-pdf-builder": "*",
    "@stamhoofd/networking": "*",
    "@stamhoofd/scss": "*",
    "@stamhoofd/structures": "*",
    "@stamhoofd/ticket-builder": "*",
    "@stamhoofd/utility": "*",
    "vue": "3.5.38",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.2/xlsx-0.20.2.tgz"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0",
    "@stamhoofd/vite-config": "*",
    "@trapezedev/configure": "7.1.4",
    "eslint-plugin-stamhoofd": "*",
    "vite": "8.0.16"
  }
}
