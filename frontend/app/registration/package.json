{
    "name": "@stamhoofd/registration",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "main": "src/exports.ts",
    "scripts": {
        "dev:build": "yarn -s build",
        "build": "NODE_OPTIONS=\"--max-old-space-size=8192 --max-semi-space-size=128\" NODE_ENV=development ENV_FILE=../../.env.json vite build",
        "build:production": "NODE_OPTIONS=\"--max-old-space-size=8192 --max-semi-space-size=128\" NODE_ENV=production vite build",
        "typecheck": "vue-tsc --noEmit",
        "lint": "eslint"
    },
    "files": [
        "dist"
    ],
    "dependencies": {
        "@stamhoofd/assets": "1.0.0",
        "@stamhoofd/components": "1.0.0",
        "@stamhoofd/scss": "1.0.0",
        "@stamhoofd/structures": "*",
        "@stamhoofd/utility": "*"
    }
}
