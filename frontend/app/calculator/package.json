{
    "name": "@stamhoofd/calculator",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "STAMHOOFD_ENV=stamhoofd NODE_ENV=development ENV_FILE=../../.env.json vite",
        "dev:preview": "STAMHOOFD_ENV=stamhoofd NODE_ENV=development ENV_FILE=../../.env.json concurrently -r 'vite build' 'vite preview'",
        "production:preview": "cp preview/* dist/ && STAMHOOFD_ENV=stamhoofd NODE_ENV=development vite preview",
        "build": "NODE_OPTIONS=\"--max-old-space-size=8192 --max-semi-space-size=128\" NODE_ENV=development ENV_FILE=../../.env.json vite build",
        "build:production": "NODE_OPTIONS=\"--max-old-space-size=8192 --max-semi-space-size=128\" NODE_ENV=production vite build",
        "lint": "eslint"
    },
    "files": [
        "dist"
    ],
    "dependencies": {
        "@simonbackx/simple-errors": "^1.5",
        "@simonbackx/vue-app-navigation": "2.20.1",
        "@stamhoofd/assets": "*",
        "@stamhoofd/components": "*",
        "@stamhoofd/document-helper": "*",
        "@stamhoofd/frontend-excel-export": "*",
        "@stamhoofd/frontend-i18n": "*",
        "@stamhoofd/frontend-pdf-builder": "*",
        "@stamhoofd/networking": "*",
        "@stamhoofd/scss": "*",
        "@stamhoofd/structures": "*",
        "@stamhoofd/ticket-builder": "*",
        "@stamhoofd/types": "*",
        "@stamhoofd/utility": "*",
        "vue": "3.5.38"
    },
    "devDependencies": {
        "eslint-plugin-stamhoofd": "*",
        "vite": "^8.0.0"
    }
}
