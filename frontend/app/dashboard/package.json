{
    "name": "@stamhoofd/dashboard",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "main": "./src/exports.ts",
    "scripts": {
        "dev": "NODE_ENV=development ENV_FILE=../../.env.json vite",
        "dev:build": "pnpm -s build",
        "build": "pnpm -s typecheck && NODE_OPTIONS=\"--max-old-space-size=8192 --max-semi-space-size=128\" NODE_ENV=development ENV_FILE=../../.env.json vite build",
        "build:playwright": "NODE_ENV=test STAMHOOFD_ENV=playwright vite build",
        "build:production": "pnpm -s typecheck && NODE_OPTIONS=\"--max-old-space-size=8192 --max-semi-space-size=128\" NODE_ENV=production vite build",
        "test": "pnpm -s typecheck",
        "lint": "eslint",
        "typecheck": "vue-tsc --noEmit"
    },
    "files": [
        "dist"
    ],
    "dependencies": {
        "@simonbackx/simple-encoding": "2.26.6",
        "@simonbackx/simple-errors": "^1.5.0",
        "@simonbackx/simple-networking": "1.23.0",
        "@simonbackx/vue-app-navigation": "2.18.1",
        "@stamhoofd/admin-frontend": "*",
        "@stamhoofd/assets": "*",
        "@stamhoofd/utility": "*",
        "@stamhoofd/components": "*",
        "@stamhoofd/document-helper": "*",
        "@stamhoofd/frontend-excel-export": "*",
        "@stamhoofd/frontend-i18n": "*",
        "@stamhoofd/frontend-pdf-builder": "*",
        "@stamhoofd/ticket-builder": "*",
        "@stamhoofd/networking": "*",
        "@stamhoofd/registration": "*",
        "@stamhoofd/scss": "*",
        "@stamhoofd/structures": "*",
        "@stamhoofd/types": "*",
        "luxon": "3.4.4",
        "qr-scanner": "^1.3.0"
    },
    "devDependencies": {
        "@types/luxon": "3.4.2"
    }
}
