{
    "name": "@stamhoofd/sgv-frontend",
    "version": "1.0.0",
    "private": true,
    "main": "index.ts",
    "dependencies": {
        "@stamhoofd/assets": "1.0.0"
    },
    "type": "module",
    "exports": {
        ".": "./src/index.ts",
        "./*": "./src/*.ts",
        "./*.ts": "./src/*.ts",
        "./*.vue": "./src/*.vue"
    },
    "imports": {
        "#*": "./src/*.ts",
        "#*.vue": "./src/*.vue",
        "#*.ts": "./src/*.ts"
    },
    "scripts": {
        "lint": "eslint",
        "typecheck": "vue-tsc --noEmit"
    }
}
