{
    "name": "@stamhoofd/networking",
    "version": "1.0.0",
    "private": true,
    "main": "index.ts",
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": "./index.ts",
        "./*": "./src/*.ts",
        "./*.ts": "./src/*.ts",
        "./*.vue": "./src/*.vue"
    },
    "scripts": {
        "lint": "eslint",
        "typecheck": "vue-tsc --noEmit"
    },
    "imports": {
        "#*.vue": "./src/*.vue",
        "#*.ts": "./src/*.ts",
        "#*": "./src/*.ts"
    }
}
