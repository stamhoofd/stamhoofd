        "@simonbackx/simple-errors": "^1.5.0",
        "@simonbackx/simple-networking": "1.23.0",
        "@simonbackx/vue-app-navigation": "2.18.1",
        "@stamhoofd/admin-frontend": "*",
        "@stamhoofd/assets": "*",
        "@stamhoofd/dashboard": "*",
        "@stamhoofd/frontend-excel-export": "*",
        "@stamhoofd/frontend-i18n": "*",
        "@stamhoofd/frontend-pdf-builder": "*",
        "@stamhoofd/locales": "*",
        "@stamhoofd/networking": "*",
        "@stamhoofd/object-differ": "*",
        "@stamhoofd/registration": "*",
        "@stamhoofd/scss": "*",
