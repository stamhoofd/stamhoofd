{
    "name": "@stamhoofd/components",
    "version": "1.0.0",
    "private": true,
    "main": "index.ts",
    "type": "module",
    "sideEffects": false,
    "scripts": {
        "lint": "eslint",
        "typecheck": "vue-tsc --noEmit"
