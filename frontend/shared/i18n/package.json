{
    "name": "@stamhoofd/frontend-i18n",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "sideEffects": false,
    "exports": {
        "./*": "./*.ts",
        "./*.ts": "./*.ts",
        "./*.vue": "./*.vue"
    },
    "imports": {
        "#*.vue": "./*.vue",
        "#*.ts": "./*.ts",
        "#*": "./*.ts"
    },
    "scripts": {
        "lint": "eslint",
        "typecheck": "vue-tsc --noEmit"
    },
    "dependencies": {
        "@simonbackx/vue-app-navigation": "2.24.1",
        "@stamhoofd/locales": "*",
        "@stamhoofd/networking": "*",
        "@stamhoofd/structures": "*",
        "@stamhoofd/types": "*",
        "@stamhoofd/utility": "*",
        "vue": "3.5.40"
    },
    "devDependencies": {
        "eslint-plugin-stamhoofd": "*"
    }
}
