{
    "name": "@stamhoofd/frontend-i18n",
    "version": "1.0.0",
    "private": true,
    "main": "index.ts",
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": "./index.ts",
        "./*": "./*.ts",
        "./*.ts": "./*.ts",
        "./*.vue": "./*.vue"
    },
    "imports": {
        "#*.vue": "./*.vue",
        "#*.ts": "./*.ts",
        "#*": "./*.ts"
    },
    "scripts": {
        "lint": "eslint",
        "typecheck": "vue-tsc --noEmit"
    }
}
